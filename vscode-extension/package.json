{
  "name": "ai-serviter-vscode",
  "displayName": "AI Serviter",
  "description": "VS Code scaffold for AI Serviter coding module",
  "version": "0.1.0",
  "publisher": "local-dev",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:aiServiter.analyze",
    "onCommand:aiServiter.plan"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiServiter.analyze",
        "title": "AI Serviter: Analyze Workspace"
      },
      {
        "command": "aiServiter.plan",
        "title": "AI Serviter: Plan Coding Task"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  }
}
